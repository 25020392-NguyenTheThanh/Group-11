<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="mainPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="850.0" prefWidth="1280.0" style="-fx-background-color: #0A192F;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.group11.controller.AuctionListController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="25.0" style="-fx-background-color: #0A192F; -fx-border-color: transparent transparent #1E2D45 transparent; -fx-border-width: 1;" BorderPane.alignment="CENTER">
            <children>
                <Label text="HANK AUCTIONS" textFill="#ffd700">
                    <font><Font name="System Bold Italic" size="22.0" /></font>
                </Label>
                <TextField fx:id="searchBar" prefHeight="35.0" prefWidth="220.0" promptText="Tìm ID/Tên..." style="-fx-background-color: #112240; -fx-text-fill: white; -fx-border-color: #1E2D45; -fx-border-radius: 8; -fx-background-radius: 8;" />

                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <Button fx:id="allLIst" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #94A3B8; -fx-font-weight: bold; -fx-font-size: 11;" text="TẤT CẢ" />

                        <MenuButton fx:id="auctionStatus" mnemonicParsing="false" style="-fx-background-color: transparent;" text="TRẠNG THÁI" textFill="#94a3b8">
                            <items>
                                <MenuItem mnemonicParsing="false" text="Open" />
                                <MenuItem mnemonicParsing="false" text="Running" />
                                <MenuItem mnemonicParsing="false" text="Finished" />
                            </items>
                            <font><Font name="System Bold" size="11.0" /></font>
                        </MenuButton>

                        <MenuButton fx:id="auctionProduct" mnemonicParsing="false" style="-fx-background-color: transparent;" text="SẢN PHẨM" textFill="#94a3b8">
                            <items>
                                <MenuItem mnemonicParsing="false" text="Electronics" />
                                <MenuItem mnemonicParsing="false" text="Art" />
                                <MenuItem mnemonicParsing="false" text="Vehicle" />
                            </items>
                            <font><Font name="System Bold" size="11.0" /></font>
                        </MenuButton>
                    </children>
                </HBox>

                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="SystemNotification" mnemonicParsing="false" style="-fx-background-color: transparent;" text="🔔" textFill="WHITE">
                    <font><Font size="18.0" /></font>
                </Button>
                <Circle fx:id="Avarta" fill="#ffd700" radius="18.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" />
            </children>
            <padding><Insets left="30.0" right="30.0" /></padding>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="240.0" spacing="5.0" style="-fx-background-color: #0A192F; -fx-border-color: transparent #1E2D45 transparent transparent;" BorderPane.alignment="CENTER">
            <children>
                <VBox fx:id="autionLive" spacing="5.0" style="-fx-background-color: rgba(17, 34, 64, 0.5); -fx-background-radius: 12;">
                    <children>
                        <Label text="Hammer Portal" textFill="WHITE"><font><Font name="System Bold" size="14.0" /></font></Label>
                        <Label text="Live Marketplace" textFill="#94a3b8"><font><Font size="10.0" /></font></Label>
                    </children>
                    <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                    <VBox.margin><Insets bottom="20.0" left="15.0" right="15.0" top="20.0" /></VBox.margin>
                </VBox>

                <Button fx:id="btnDashboardS" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#handleSwitchTab" prefHeight="50.0" text="   DASHBOARD" />
                <Button fx:id="btnMyBids" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#handleSwitchTab" prefHeight="50.0" text="   MY BIDS" />
                <Button fx:id="btnWatchlist" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#handleSwitchTab" prefHeight="50.0" text="   WATCHLIST" />
                <Button fx:id="btnHistory" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#handleSwitchTab" prefHeight="50.0" text="   HISTORY" />
                <Button fx:id="btnSettings" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#handleSwitchTab" prefHeight="50.0" text="   SETTINGS" />

                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="sellItem" maxWidth="1.7976931348623157E308" prefHeight="45.0" style="-fx-background-color: #FFD700; -fx-background-radius: 12; -fx-text-fill: #0A192F; -fx-font-weight: 900;" text="SELL ITEM">
                    <VBox.margin><Insets bottom="20.0" left="20.0" right="20.0" /></VBox.margin>
                </Button>
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="30.0">
                    <children>
                        <HBox alignment="BOTTOM_LEFT">
                            <children>
                                <VBox HBox.hgrow="ALWAYS">
                                    <children>
                                        <HBox alignment="BOTTOM_LEFT">
                                            <children>
                                                <Label text="KẾT QUẢ: " textFill="WHITE"><font><Font name="System Bold" size="28.0" /></font></Label>
                                                <Label text="120 Phiên đấu giá" textFill="#ffd700"><font><Font name="System Bold" size="28.0" /></font></Label>
                                            </children>
                                        </HBox>
                                        <Label text="Duyệt qua các vật phẩm đang diễn ra trong thời gian thực." textFill="#94a3b8" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <GridPane hgap="25.0" vgap="25.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="10.0" prefHeight="400.0" vgrow="SOMETIMES" />
                            </rowConstraints>
                            <children>
                                <VBox style="-fx-background-color: rgba(17, 34, 64, 0.4); -fx-background-radius: 20; -fx-border-color: #1E2D45; -fx-border-radius: 20;">
                                    <children>
                                        <StackPane prefHeight="200.0" style="-fx-background-color: #112240; -fx-background-radius: 20 20 0 0;" />
                                        <VBox spacing="15.0" VBox.vgrow="ALWAYS">
                                            <children>
                                                <Label text="Laptop Gaming ASUS ROG" textFill="WHITE" wrapText="true"><font><Font name="System Bold" size="16.0" /></font></Label>
                                                <Label text="18.000.000đ" textFill="#ffd700"><font><Font name="System Bold" size="20.0" /></font></Label>
                                                <Button maxWidth="1.7976931348623157E308" prefHeight="45.0" style="-fx-background-color: #FFD700; -fx-background-radius: 10; -fx-text-fill: #0A192F; -fx-font-weight: bold;" text="ĐẶT GIÁ" />
                                            </children>
                                            <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </GridPane>
                    </children>
                    <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
