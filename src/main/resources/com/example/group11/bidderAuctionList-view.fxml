<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.layout.RowConstraints?>
<StackPane alignment="TOP_RIGHT" prefHeight="750.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.group11.controller.BidderAuctionListController">
    <children>
        <!-- GIAO DIỆN CHÍNH (BorderPane) -->
        <BorderPane fx:id="mainPane" style="-fx-background-color: #0A192F;">

            <!-- HEADER (TOP) -->
            <top>
                <HBox alignment="CENTER_LEFT" prefHeight="75.0" spacing="20.0" style="-fx-background-color: #0A192F; -fx-border-color: transparent transparent #1E2D45 transparent; -fx-border-width: 1;" BorderPane.alignment="CENTER">
                    <children>
                        <!-- LOGO -->
                        <Label text="HANK AUCTIONS" textFill="#ffd700">
                            <font><Font name="System Bold Italic" size="22.0" /></font>
                        </Label>

                        <!-- THANH TÌM KIẾM -->
                        <TextField fx:id="searchBar" prefHeight="35.0" prefWidth="200.0" promptText="Tìm ID/Tên..." style="-fx-background-color: #112240; -fx-text-fill: white; -fx-border-color: #1E2D45; -fx-border-radius: 8; -fx-background-radius: 8;" />

                        <!-- BỘ LỌC -->
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Button fx:id="allList" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #94A3B8; -fx-font-weight: bold; -fx-font-size: 12;" text="TẤT CẢ" />
                                <MenuButton fx:id="auctionStatus" mnemonicParsing="false" style="-fx-background-color: transparent;" text="TRẠNG THÁI" textFill="#94a3b8">
                                    <items>
                                        <MenuItem mnemonicParsing="false" text="Open" />
                                        <MenuItem mnemonicParsing="false" text="Running" />
                                        <MenuItem mnemonicParsing="false" text="Finished" />
                                    </items>
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </MenuButton>
                                <MenuButton fx:id="auctionProduct" mnemonicParsing="false" style="-fx-background-color: transparent;" text="SẢN PHẨM" textFill="#94a3b8">
                                    <items>
                                        <MenuItem mnemonicParsing="false" text="Electronics" />
                                        <MenuItem mnemonicParsing="false" text="Art" />
                                        <MenuItem mnemonicParsing="false" text="Vehicle" />
                                    </items>
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </MenuButton>
                            </children>
                        </HBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <!-- KHU VỰC TIỆN ÍCH BÊN PHẢI -->
                        <HBox alignment="CENTER" spacing="15.0">
                            <children>
                                <!-- THANH SỐ DƯ -->
                                <HBox alignment="CENTER" prefHeight="35.0" spacing="8.0" style="-fx-background-color: #112240; -fx-border-color: #1E2D45; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 12 0 12;">
                                    <children>
                                        <Label textFill="#94A3B8" text="\$">
                                            <font><Font name="System Bold" size="14.0" /></font>
                                        </Label>
                                        <Label fx:id="walletBalance" minWidth="50.0" text="0.00" textFill="#ffd700">
                                            <font><Font name="System Bold" size="14.0" /></font>
                                        </Label>
                                        <Button fx:id="addFundsBtn" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0 0 0 5;" text="+" textFill="#22c55e">
                                            <font><Font name="System Bold" size="18.0" /></font>
                                        </Button>
                                    </children>
                                </HBox>

                                <!-- CHUÔNG THÔNG BÁO -->
                                <Button fx:id="SystemNotification" onAction="#handleShowNotifications" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-cursor: hand;" text="🔔" textFill="WHITE">
                                    <font><Font size="20.0" /></font>
                                </Button>

                                <!-- AVATAR BUTTON -->
                                <VBox alignment="CENTER" spacing="2.0">
                                    <children>
                                        <Button fx:id="avatarBtn" onAction="#toggleProfileDropdown" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0;">
                                            <graphic>
                                                <StackPane>
                                                    <children>
                                                        <Circle fill="#e2e8f0" radius="18.0" stroke="#94a3b8" strokeType="INSIDE" strokeWidth="1.0" />
                                                        <Label text="👤" textFill="#475569">
                                                            <font><Font size="18.0" /></font>
                                                        </Label>
                                                    </children>
                                                </StackPane>
                                            </graphic>
                                        </Button>
                                        <Label text="Bidder" textFill="#94a3b8">
                                            <font><Font name="System Bold" size="10.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                    <padding><Insets left="30.0" right="30.0" /></padding>
                </HBox>
            </top>

            <!-- SIDEBAR (LEFT) -->
            <left>
                <VBox prefWidth="240.0" spacing="2.0" style="-fx-background-color: #0A192F; -fx-border-color: transparent #1E2D45 transparent transparent;" BorderPane.alignment="CENTER">
                    <children>
                        <VBox fx:id="auctionLive" onMouseClicked="#handleHammerPortalClick" spacing="5.0" style="-fx-background-color: rgba(17, 34, 64, 0.5); -fx-background-radius: 12; -fx-cursor: hand;">
                            <children>
                                <Label text="Hammer Portal" textFill="WHITE"><font><Font name="System Bold" size="14.0" /></font></Label>
                                <Label text="Live Marketplace" textFill="#94a3b8"><font><Font size="10.0" /></font></Label>
                            </children>
                            <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                            <VBox.margin><Insets bottom="20.0" left="15.0" right="15.0" top="20.0" /></VBox.margin>
                        </VBox>

                        <Button fx:id="btnDashboardS" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#handleSwitchTab" prefHeight="50.0" style="-fx-background-color: transparent; -fx-text-fill: #94A3B8;" text="   DASHBOARD">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Button>
                        <Button fx:id="btnMyBids" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#handleSwitchTab" prefHeight="50.0" style="-fx-background-color: transparent; -fx-text-fill: #94A3B8;" text="   MY BIDS">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Button>
                        <Button fx:id="btnWatchlist" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#handleSwitchTab" prefHeight="50.0" style="-fx-background-color: transparent; -fx-text-fill: #94A3B8;" text="   WATCHLIST">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Button>
                        <Button fx:id="btnHistory" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#handleSwitchTab" prefHeight="50.0" style="-fx-background-color: transparent; -fx-text-fill: #94A3B8;" text="   HISTORY">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Button>
                        <Button fx:id="btnSettings" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" onAction="#handleSwitchTab" prefHeight="50.0" style="-fx-background-color: transparent; -fx-text-fill: #94A3B8;" text="   SETTINGS">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Button>
                    </children>
                </VBox>
            </left>

            <!-- CENTER CONTENT -->
            <center>
                <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" BorderPane.alignment="CENTER">
                    <content>
                        <VBox spacing="30.0">
                            <children>
                                <VBox fx:id="headerSection" spacing="5.0">
                                    <children>
                                        <HBox alignment="BOTTOM_LEFT" spacing="10.0">
                                            <children>
                                                <Label text="TỔNG CÁC PHIÊN ĐẤU GIÁ :" textFill="WHITE">
                                                    <font><Font name="System Bold" size="24.0" /></font>
                                                </Label>
                                                <Label fx:id="totalAuctionsLabel" text="0" textFill="#ffd700">
                                                    <font><Font name="System Bold" size="24.0" /></font>
                                                </Label>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <GridPane fx:id="contentGrid" hgap="25.0" vgap="25.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                    </columnConstraints>
                                </GridPane>
                            </children>
                            <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
                        </VBox>
                    </content>
                </ScrollPane>
            </center>
        </BorderPane>

        <!-- MENU DROPDOWN CỦA PROFILE (Nổi lên trên cùng) -->
        <VBox fx:id="profileDropdown" maxHeight="90.0" maxWidth="180.0" managed="false" visible="false" spacing="5.0"
              style="-fx-background-color: #112240; -fx-border-color: #1E2D45; -fx-border-width: 1.5; -fx-border-radius: 12; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.6), 15, 0, 0, 5);">
            <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>
            <StackPane.margin><Insets right="30.0" top="75.0" /></StackPane.margin>
            <children>
                <Button fx:id="btnProfileInfo" onAction="#handleViewProfile" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" style="-fx-background-color: transparent; -fx-text-fill: #94A3B8; -fx-cursor: hand;" text="👤  Thông tin cá nhân">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
                <Region prefHeight="1.0" style="-fx-background-color: #1E2D45;" />
                <Button fx:id="btnLogout" onAction="#handleLogout" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" style="-fx-background-color: transparent; -fx-text-fill: #E11D48; -fx-cursor: hand;" text="🚪  Đăng xuất">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
            </children>
        </VBox>

        <VBox fx:id="notificationDropdown" maxHeight="300.0" maxWidth="250.0" managed="false" visible="false" spacing="10.0"
              style="-fx-background-color: #112240; -fx-border-color: #1E2D45; -fx-border-width: 1.5; -fx-border-radius: 12; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.6), 15, 0, 0, 5);">
            <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
            <StackPane.margin><Insets right="80.0" top="75.0" /></StackPane.margin>
            <children>
                <Label text="Thông báo mới nhất" textFill="#FFD700">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Label>
                <Region prefHeight="1.0" style="-fx-background-color: #1E2D45;" />
                <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
                    <content>
                        <VBox fx:id="notificationListContainer" spacing="8.0" style="-fx-background-color: transparent;">
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </VBox>

        <!-- OVERLAY NẠP TIỀN (CENTERED MODAL) -->
        <StackPane fx:id="addFundsOverlay" visible="false" managed="false" style="-fx-background-color: rgba(0, 0, 0, 0.75);">
            <children>
                <VBox alignment="CENTER" spacing="20.0" maxHeight="380.0" maxWidth="580.0"
                      style="-fx-background-color: #112240; -fx-border-color: #1E2D45; -fx-border-width: 2; -fx-border-radius: 16; -fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.8), 20, 0, 0, 10);">
                    <padding><Insets bottom="25.0" left="25.0" right="25.0" top="25.0" /></padding>
                    <children>
                        <!-- Header -->
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Label text="CHỌN GÓI NẠP TIỀN" textFill="#FFD700">
                                    <font><Font name="System Bold" size="18.0" /></font>
                                </Label>
                                <Region HBox.hgrow="ALWAYS" />
                                <Button onAction="#handleCloseAddFunds" style="-fx-background-color: transparent; -fx-text-fill: #94A3B8; -fx-font-weight: bold; -fx-font-size: 16; -fx-cursor: hand;" text="✕" />
                            </children>
                        </HBox>
                        
                        <Region prefHeight="1.0" style="-fx-background-color: #1E2D45;" />

                        <!-- Grid 6 gói nạp -->
                        <GridPane hgap="15.0" vgap="15.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" percentWidth="33.3" />
                                <ColumnConstraints hgrow="SOMETIMES" percentWidth="33.3" />
                                <ColumnConstraints hgrow="SOMETIMES" percentWidth="33.3" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="90.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="90.0" vgrow="SOMETIMES" />
                            </rowConstraints>
                            <children>
                                <!-- Gói 1: 1.000 -->
                                <VBox fx:id="package1" onMouseClicked="#handleSelectPackage" alignment="CENTER" spacing="5.0"
                                      style="-fx-background-color: #1E2D45; -fx-border-color: #334155; -fx-border-width: 1.5; -fx-border-radius: 10; -fx-background-radius: 10; -fx-cursor: hand;"
                                      userData="1000">
                                    <children>
                                        <Label text="1.000$" textFill="WHITE">
                                            <font><Font name="System Bold" size="16.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>
                                
                                <!-- Gói 2: 2.000 -->
                                <VBox fx:id="package2" onMouseClicked="#handleSelectPackage" alignment="CENTER" spacing="5.0" GridPane.columnIndex="1"
                                      style="-fx-background-color: #1E2D45; -fx-border-color: #334155; -fx-border-width: 1.5; -fx-border-radius: 10; -fx-background-radius: 10; -fx-cursor: hand;"
                                      userData="2000">
                                    <children>
                                        <Label text="2.000$" textFill="WHITE">
                                            <font><Font name="System Bold" size="16.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>
                                
                                <!-- Gói 3: 5.000 -->
                                <VBox fx:id="package3" onMouseClicked="#handleSelectPackage" alignment="CENTER" spacing="5.0" GridPane.columnIndex="2"
                                      style="-fx-background-color: #1E2D45; -fx-border-color: #334155; -fx-border-width: 1.5; -fx-border-radius: 10; -fx-background-radius: 10; -fx-cursor: hand;"
                                      userData="5000">
                                    <children>
                                        <Label text="5.000$" textFill="WHITE">
                                            <font><Font name="System Bold" size="16.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>
                                
                                <!-- Gói 4: 10.000 -->
                                <VBox fx:id="package4" onMouseClicked="#handleSelectPackage" alignment="CENTER" spacing="5.0" GridPane.rowIndex="1"
                                      style="-fx-background-color: #1E2D45; -fx-border-color: #334155; -fx-border-width: 1.5; -fx-border-radius: 10; -fx-background-radius: 10; -fx-cursor: hand;"
                                      userData="10000">
                                    <children>
                                        <Label text="10.000$" textFill="WHITE">
                                            <font><Font name="System Bold" size="16.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>
                                
                                <!-- Gói 5: 20.000 -->
                                <VBox fx:id="package5" onMouseClicked="#handleSelectPackage" alignment="CENTER" spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1"
                                      style="-fx-background-color: #1E2D45; -fx-border-color: #334155; -fx-border-width: 1.5; -fx-border-radius: 10; -fx-background-radius: 10; -fx-cursor: hand;"
                                      userData="20000">
                                    <children>
                                        <Label text="20.000$" textFill="WHITE">
                                            <font><Font name="System Bold" size="16.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>
                                
                                <!-- Gói 6: 50.000 -->
                                <VBox fx:id="package6" onMouseClicked="#handleSelectPackage" alignment="CENTER" spacing="5.0" GridPane.columnIndex="2" GridPane.rowIndex="1"
                                      style="-fx-background-color: #1E2D45; -fx-border-color: #334155; -fx-border-width: 1.5; -fx-border-radius: 10; -fx-background-radius: 10; -fx-cursor: hand;"
                                      userData="50000">
                                    <children>
                                        <Label text="50.000$" textFill="WHITE">
                                            <font><Font name="System Bold" size="16.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                        </GridPane>
                    </children>
                </VBox>
            </children>
        </StackPane>

    </children>
</StackPane>