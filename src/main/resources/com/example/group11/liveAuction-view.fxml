<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.XYChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane
        prefHeight="800.0" prefWidth="1280.0"
        style="-fx-background-color: #131315; -fx-font-family: 'Segoe UI', Inter, sans-serif;"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.example.group11.controller.LiveAuctionController">

    <top>
        <HBox alignment="CENTER_LEFT" minHeight="80" spacing="20"
              style="-fx-background-color: #0f172a; -fx-border-color: #45464d; -fx-border-width: 0 0 1 0;">
            <padding><Insets left="40" right="40" /></padding>

            <!-- ✅ fx:id="backButton" + onAction="#handleBack" -->
            <Button fx:id="backButton" onAction="#handleBack"
                    style="-fx-background-color: #1b1b1d; -fx-text-fill: #e4e2e4;
                           -fx-border-color: #45464d; -fx-border-radius: 8;
                           -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;"
                    text="&lt;- Quay lại" />

            <VBox spacing="2">
                <Label style="-fx-text-fill: #FFC107; -fx-font-size: 24px; -fx-font-weight: bold;"
                       text="ĐẤU GIÁ TRỰC TIẾP" />
                <!-- ✅ fx:id="productNameLabel" -->
                <Label fx:id="productNameLabel"
                       style="-fx-text-fill: #909097; -fx-font-size: 13px;"
                       text="Đang tải..." />
            </VBox>
        </HBox>
    </top>

    <center>
        <HBox spacing="24">
            <padding><Insets bottom="24" left="40" right="40" top="24" /></padding>

            <!-- ===== CỘT TRÁI: Thông tin sản phẩm ===== -->
            <VBox prefWidth="300" spacing="15" HBox.hgrow="ALWAYS">
                <Label style="-fx-text-fill: #ffb95f; -fx-font-size: 12px; -fx-font-weight: bold;"
                       text="SẢN PHẨM ĐANG ĐẤU" />

                <!-- ✅ fx:id="productImageContainer" — chứa ảnh sản phẩm -->
                <StackPane fx:id="productImageContainer" minHeight="300"
                           style="-fx-background-color: #1b1b1d; -fx-border-color: #45464d;
                                  -fx-border-radius: 12; -fx-background-radius: 12;">
                    <Label fx:id="productImagePlaceholder"
                           style="-fx-text-fill: #909097; -fx-text-alignment: center;"
                           text="Hình ảnh sản phẩm" />
                </StackPane>

                <!-- ✅ fx:id="itemNameLabel" -->
                <Label fx:id="itemNameLabel"
                       style="-fx-text-fill: #e4e2e4; -fx-font-size: 22px; -fx-font-weight: bold;"
                       text="..." wrapText="true"/>
                <!-- ✅ fx:id="itemDescLabel" -->
                <Label fx:id="itemDescLabel"
                       style="-fx-text-fill: #909097; -fx-font-size: 14px;"
                       text="..." wrapText="true"/>
            </VBox>

            <!-- ===== CỘT GIỮA: Giá + Biểu đồ ===== -->
            <VBox prefWidth="500" spacing="20" HBox.hgrow="ALWAYS">

                <!-- Timer bar -->
                <HBox alignment="CENTER_LEFT"
                      style="-fx-background-color: #1b1b1d; -fx-border-color: #45464d;
                             -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 15;">
                    <Label style="-fx-text-fill: #ffb4ab; -fx-background-color: #3a0003;
                                  -fx-padding: 4 8; -fx-border-radius: 12;
                                  -fx-background-radius: 12; -fx-font-weight: bold;
                                  -fx-font-size: 11px;" text="● TRỰC TIẾP" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label style="-fx-text-fill: #909097; -fx-font-size: 12px; -fx-padding: 0 10 0 0;"
                           text="THỜI GIAN CÒN LẠI" />
                    <!-- ✅ fx:id="timerLabel" -->
                    <Label fx:id="timerLabel"
                           style="-fx-text-fill: #ffb95f; -fx-font-size: 24px; -fx-font-weight: bold;"
                           text="--:--:--" />
                </HBox>

                <!-- Giá cao nhất -->
                <VBox alignment="CENTER" spacing="10"
                      style="-fx-background-color: #1a1a1c; -fx-border-color: #45464d;
                             -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 24;">
                    <Label style="-fx-text-fill: #909097; -fx-font-size: 12px;"
                           text="GIÁ CAO NHẤT HIỆN TẠI" />
                    <!-- ✅ fx:id="currentPriceLabel" -->
                    <Label fx:id="currentPriceLabel"
                           style="-fx-text-fill: #ffb95f; -fx-font-size: 40px; -fx-font-weight: bold;"
                           text= "$0" />
                    <!-- ✅ fx:id="currentWinnerLabel" -->
                    <Label fx:id="currentWinnerLabel"
                           style="-fx-text-fill: #e4e2e4; -fx-font-size: 14px;"
                           text="Đầu thầu: —" />

                    <Region prefHeight="10" />

                    <HBox alignment="CENTER" spacing="15">
                        <HBox alignment="CENTER" spacing="5">
                            <!-- ✅ fx:id="totalWatchersLabel" -->
                            <Label fx:id="totalWatchersLabel"
                                   style="-fx-text-fill: #ffb95f; -fx-font-size: 14px; -fx-font-weight: bold;"
                                   text="👁 0" />
                            <Label style="-fx-text-fill: #909097; -fx-font-size: 10px;" text="NGƯỜI XEM" />
                        </HBox>
                        <Region prefWidth="10" />
                        <HBox alignment="CENTER" spacing="5">
                            <!-- ✅ fx:id="totalBidsLabel" -->
                            <Label fx:id="totalBidsLabel"
                                   style="-fx-text-fill: #ffb95f; -fx-font-size: 14px; -fx-font-weight: bold;"
                                   text="🔨 0" />
                            <Label style="-fx-text-fill: #909097; -fx-font-size: 10px;" text="LƯỢT ĐẶT" />
                        </HBox>
                    </HBox>
                </VBox>

                <!-- Biểu đồ -->
                <VBox spacing="10"
                      style="-fx-background-color: #1b1b1d; -fx-border-color: #45464d;
                             -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 15;"
                      VBox.vgrow="ALWAYS">
                    <Label style="-fx-text-fill: #909097; -fx-font-size: 12px; -fx-font-weight: bold;"
                           text="BIỂU ĐỒ XU HƯỚNG GIÁ (Live)" />
                    <!-- ✅ fx:id="priceChart" -->
                    <LineChart fx:id="priceChart"
                               createSymbols="true" legendVisible="false" animated="false"
                               style="-fx-background-color: transparent;"
                               VBox.vgrow="ALWAYS">
                        <xAxis>
                            <!-- ✅ fx:id="chartXAxis" -->
                            <NumberAxis fx:id="chartXAxis"
                                        autoRanging="false" lowerBound="0"
                                        tickUnit="5" upperBound="30" />
                        </xAxis>
                        <yAxis>
                            <!-- ✅ fx:id="chartYAxis" -->
                            <NumberAxis fx:id="chartYAxis" autoRanging="true" />
                        </yAxis>
                    </LineChart>
                </VBox>
            </VBox>

            <!-- ===== CỘT PHẢI: Lịch sử bid + Bàn đặt giá ===== -->
            <VBox prefWidth="400" spacing="20" HBox.hgrow="ALWAYS">

                <!-- Lịch sử bid -->
                <VBox style="-fx-background-color: #1a1a1c; -fx-border-color: #45464d;
                             -fx-border-radius: 12; -fx-background-radius: 12;"
                      VBox.vgrow="ALWAYS">
                    <Label style="-fx-text-fill: #909097; -fx-font-size: 12px;
                                  -fx-padding: 15; -fx-border-color: #45464d;
                                  -fx-border-width: 0 0 1 0;" text="LỊCH SỬ ĐẶT GIÁ" />
                    <ScrollPane fitToWidth="true"
                                style="-fx-background: #1a1a1c; -fx-background-color: transparent;
                                       -fx-control-inner-background: transparent;
                                       -fx-border-color: transparent;"
                                VBox.vgrow="ALWAYS">
                        <!-- ✅ fx:id="bidHistoryContainer" — controller sẽ thêm row vào đây -->
                        <VBox fx:id="bidHistoryContainer" spacing="8"
                              style="-fx-padding: 15;" />
                    </ScrollPane>
                </VBox>

                <!-- Bàn đặt giá -->
                <VBox spacing="15"
                      style="-fx-background-color: #353436; -fx-border-color: #ffb95f;
                             -fx-border-width: 2; -fx-border-radius: 12;
                             -fx-background-radius: 12; -fx-padding: 20;">
                    <Label style="-fx-text-fill: #ffb95f; -fx-font-size: 12px; -fx-font-weight: bold;"
                           text="BÀN ĐẶT GIÁ" />

                    <!-- ✅ 3 nút cộng nhanh — onAction="#addBidXxx" -->
                    <HBox spacing="10">
                        <Button maxWidth="Infinity"
                                style="-fx-background-color: #1b1b1d; -fx-text-fill: #e4e2e4;
                                       -fx-border-color: #45464d; -fx-border-radius: 4;
                                       -fx-background-radius: 4; -fx-padding: 8; -fx-cursor: hand;"
                                text="+$100" onAction="#addBid100" HBox.hgrow="ALWAYS" />
                        <Button maxWidth="Infinity"
                                style="-fx-background-color: #1b1b1d; -fx-text-fill: #e4e2e4;
                                       -fx-border-color: #45464d; -fx-border-radius: 4;
                                       -fx-background-radius: 4; -fx-padding: 8; -fx-cursor: hand;"
                                text="+$500" onAction="#addBid500" HBox.hgrow="ALWAYS" />
                        <Button maxWidth="Infinity"
                                style="-fx-background-color: #1b1b1d; -fx-text-fill: #e4e2e4;
                                       -fx-border-color: #45464d; -fx-border-radius: 4;
                                       -fx-background-radius: 4; -fx-padding: 8; -fx-cursor: hand;"
                                text="+$1,000" onAction="#addBid1000" HBox.hgrow="ALWAYS" />
                    </HBox>

                    <!-- ✅ fx:id="bidAmountField" -->
                    <HBox alignment="CENTER_LEFT"
                          style="-fx-background-color: #131315; -fx-border-color: #45464d;
                                 -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 15;">
                        <TextField fx:id="bidAmountField"
                                   promptText="Nhập số tiền..."
                                   style="-fx-background-color: transparent; -fx-text-fill: #ffb95f;
                                          -fx-font-size: 16px; -fx-padding: 15 0;"
                                   HBox.hgrow="ALWAYS" />
                        <Label style="-fx-text-fill: #e4e2e4; -fx-font-size: 16px;" text="USD" />
                    </HBox>

                    <!-- ✅ fx:id="confirmBidButton" + onAction="#handleConfirmBid" -->
                    <Button fx:id="confirmBidButton"
                            maxWidth="Infinity"
                            onAction="#handleConfirmBid"
                            style="-fx-background-color: #ffb95f; -fx-text-fill: #2a1700;
                                   -fx-font-size: 16px; -fx-font-weight: bold;
                                   -fx-padding: 15; -fx-background-radius: 12; -fx-cursor: hand;"
                            text="XÁC NHẬN THẦU" />
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>