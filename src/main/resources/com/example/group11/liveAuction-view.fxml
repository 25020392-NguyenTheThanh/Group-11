<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="850.0" prefWidth="1300.0" style="-fx-background-color: #0e0e10;"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.group11.controller.LiveAuctionController">

    <!-- THANH NAVBAR TRÊN CÙNG -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="75.0" spacing="20.0"
              style="-fx-background-color: #1b1b1d; -fx-border-color: #2d2d30; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets left="30.0" right="30.0" />
            </padding>
            <children>
                <Button style="-fx-background-color: #2d2d30; -fx-text-fill: white; -fx-background-radius: 10; -fx-cursor: hand;" text="← Quay lại" />

                <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <children>
                        <Label style="-fx-text-fill: #ffb95f; -fx-font-weight: bold; -fx-font-size: 18;" text="HAMMER PORTAL" />
                        <Label style="-fx-text-fill: #8e8e93; -fx-font-size: 11;" text="Hệ thống đấu giá thời gian thực v2.0" />
                    </children>
                </VBox>

                <HBox alignment="CENTER" spacing="12.0" style="-fx-background-color: #2d2d30; -fx-padding: 5 15; -fx-background-radius: 20;">
                    <children>
                        <VBox alignment="CENTER_RIGHT">
                            <children>
                                <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12;" text="Lê Anh Tuấn" />
                                <Label style="-fx-text-fill: #ffb95f; -fx-font-size: 10;" text="Số dư: $50,000" />
                            </children>
                        </VBox>
                        <Circle fill="#ffb95f" radius="18.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" />
                    </children>
                </HBox>
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <HBox spacing="30.0" style="-fx-background-color: #0e0e10;">
                    <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                    </padding>
                    <children>

                        <!-- KHUNG BÊN TRÁI: THÔNG TIN SẢN PHẨM -->
                        <VBox minWidth="360.0" spacing="20.0">
                            <children>
                                <Label style="-fx-text-fill: #ffb95f; -fx-font-size: 13; -fx-font-weight: bold;" text="SẢN PHẨM ĐANG ĐẤU" />

                                <VBox spacing="20.0" style="-fx-background-color: #1b1b1d; -fx-background-radius: 15; -fx-padding: 20; -fx-border-color: #2d2d30; -fx-border-radius: 15;">
                                    <children>
                                        <StackPane alignment="TOP_LEFT">
                                            <children>
                                                <ImageView fitWidth="320.0" pickOnBounds="true" preserveRatio="true">
                                                    <image>
                                                        <Image url="https://via.placeholder.com/400x400/1b1b1d/ffb95f?text=Rolex+Submariner" />
                                                    </image>
                                                </ImageView>
                                                <Label style="-fx-background-color: rgba(0,0,0,0.6); -fx-text-fill: white; -fx-padding: 6 12; -fx-background-radius: 8; -fx-font-weight: bold; -fx-border-color: rgba(255,255,255,0.2); -fx-border-radius: 8;" text="Mã: RL001">
                                                    <StackPane.margin>
                                                        <Insets left="15.0" top="15.0" />
                                                    </StackPane.margin>
                                                </Label>
                                            </children>
                                        </StackPane>

                                        <HBox alignment="CENTER" spacing="10.0">
                                            <children>
                                                <ImageView fitHeight="70.0" fitWidth="70.0" style="-fx-border-color: #ffb95f; -fx-border-width: 1.5; -fx-border-radius: 4;">
                                                    <image><Image url="https://via.placeholder.com/70" /></image>
                                                </ImageView>
                                                <ImageView fitHeight="70.0" fitWidth="70.0" opacity="0.6">
                                                    <image><Image url="https://via.placeholder.com/70" /></image>
                                                </ImageView>
                                                <ImageView fitHeight="70.0" fitWidth="70.0" opacity="0.6">
                                                    <image><Image url="https://via.placeholder.com/70" /></image>
                                                </ImageView>
                                                <StackPane prefHeight="70.0" prefWidth="70.0" style="-fx-background-color: #2d2d30; -fx-background-radius: 4;">
                                                    <children>
                                                        <Label style="-fx-text-fill: #8e8e93; -fx-font-weight: bold;" text="+12" />
                                                    </children>
                                                </StackPane>
                                            </children>
                                        </HBox>

                                        <VBox spacing="8.0">
                                            <children>
                                                <Label style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;" text="ROLEX SUBMARINER" />
                                                <Text fill="#8e8e93" style="-fx-font-size: 14;" text="Mới 100% Fullbox - Bảo hành toàn cầu 5 năm" wrappingWidth="320.0" />

                                                <Region prefHeight="10.0" />

                                                <HBox alignment="CENTER_LEFT" spacing="8.0" style="-fx-cursor: hand;">
                                                    <children>
                                                        <Label style="-fx-text-fill: #ffb95f; -fx-font-weight: bold; -fx-font-size: 14;" text="XEM CHI TIẾT" />
                                                        <Label style="-fx-text-fill: #ffb95f; -fx-font-size: 16;" text="→" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <!-- KHUNG GIỮA: TRẠNG THÁI ĐẤU GIÁ VÀ BIỂU ĐỒ -->
                        <VBox spacing="20.0" HBox.hgrow="ALWAYS">
                            <children>
                                <HBox alignment="CENTER_LEFT" style="-fx-background-color: #1b1b1d; -fx-background-radius: 15; -fx-padding: 15 20; -fx-border-color: #2d2d30; -fx-border-radius: 15;">
                                    <children>
                                        <HBox alignment="CENTER" spacing="8.0" style="-fx-background-color: rgba(219,68,85,0.1); -fx-border-color: #db4455; -fx-border-radius: 20; -fx-padding: 6 12;">
                                            <children>
                                                <Circle fill="#db4455" radius="4.0" />
                                                <Label style="-fx-text-fill: #db4455; -fx-font-weight: bold; -fx-font-size: 11;" text="TRỰC TIẾP" />
                                            </children>
                                        </HBox>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <HBox alignment="CENTER" spacing="15.0">
                                            <children>
                                                <Label style="-fx-text-fill: #8e8e93; -fx-font-size: 11; -fx-font-weight: bold;" text="THỜI GIAN CÒN LẠI" />
                                                <Label fx:id="timerLabel" style="-fx-text-fill: #ffb95f; -fx-font-size: 32; -fx-font-weight: bold; -fx-font-family: 'Monospaced';" text="00:28:45" />
                                            </children>
                                        </HBox>
                                    </children>
                                </HBox>

                                <VBox alignment="CENTER" spacing="15.0"
                                      style="-fx-background-color: #1b1b1d; -fx-background-radius: 15; -fx-border-color: #ffb95f; -fx-border-radius: 15; -fx-border-width: 1.5; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(255, 185, 95, 0.15), 15, 0.2, 0, 0);">
                                    <children>
                                        <Label style="-fx-text-fill: #8e8e93; -fx-font-size: 12; -fx-font-weight: bold;" text="GIÁ CAO NHẤT HIỆN TẠI" />
                                        <Label fx:id="currentPriceLabel" style="-fx-text-fill: #ffb95f; -fx-font-size: 56; -fx-font-weight: bold;" text="/$42,500" />

                                        <HBox alignment="CENTER" spacing="5.0">
                                            <children>
                                                <Label style="-fx-text-fill: #8e8e93; -fx-font-size: 13;" text="Đang dẫn đầu: " />
                                                <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13;" text="/@anhtuan_123" />
                                            </children>
                                        </HBox>

                                        <HBox alignment="CENTER" spacing="15.0">
                                            <children>
                                                <HBox alignment="CENTER" spacing="10.0" prefWidth="180.0" style="-fx-background-color: #242426; -fx-border-color: #2d2d30; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12 15;">
                                                    <children>
                                                        <Label style="-fx-text-fill: #8e8e93; -fx-font-size: 16;" text="👁" />
                                                        <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14;" text="1,845" />
                                                        <Label style="-fx-text-fill: #8e8e93; -fx-font-size: 10; -fx-font-weight: bold;" text="NGƯỜI XEM" />
                                                    </children>
                                                </HBox>
                                                <HBox alignment="CENTER" spacing="10.0" prefWidth="180.0" style="-fx-background-color: #242426; -fx-border-color: #2d2d30; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12 15;">
                                                    <children>
                                                        <Label style="-fx-text-fill: #8e8e93; -fx-font-size: 14;" text="🔨" />
                                                        <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14;" text="142" />
                                                        <Label style="-fx-text-fill: #8e8e93; -fx-font-size: 10; -fx-font-weight: bold;" text="LƯỢT ĐẶT" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox style="-fx-background-color: #1b1b1d; -fx-background-radius: 15; -fx-padding: 20; -fx-border-color: #2d2d30; -fx-border-radius: 15;" VBox.vgrow="ALWAYS">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-padding: 0 0 15 0;">
                                            <children>
                                                <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13;" text="BIỂU ĐỒ XU HƯỚNG GIÁ (LIVE)" />
                                                        <Label style="-fx-text-fill: #65666a; -fx-font-size: 10; -fx-font-weight: bold;" text="Y: GIÁ THẦU ($) | X: THỜI GIAN" />
                                                    </children>
                                                </VBox>
                                                <Label style="-fx-text-fill: #ffb95f; -fx-font-weight: bold; -fx-font-size: 10; -fx-border-color: rgba(255,185,95,0.3); -fx-border-radius: 5; -fx-padding: 3 8; -fx-background-color: rgba(255,185,95,0.05); -fx-background-radius: 5;" text="REALTIME" />
                                            </children>
                                        </HBox>
                                        <LineChart fx:id="priceChart" alternativeRowFillVisible="false" horizontalGridLinesVisible="true" legendVisible="false" verticalGridLinesVisible="false" prefHeight="220.0">
                                            <xAxis><NumberAxis side="BOTTOM" tickLabelFill="#8e8e93" /></xAxis>
                                            <yAxis><NumberAxis side="LEFT" tickLabelFill="#8e8e93" /></yAxis>
                                        </LineChart>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <!-- KHUNG BÊN PHẢI: LỊCH SỬ VÀ BÀN ĐẶT GIÁ -->
                        <VBox minWidth="380.0" spacing="20.0">
                            <children>
                                <VBox spacing="15.0" VBox.vgrow="ALWAYS" style="-fx-background-color: #1b1b1d; -fx-background-radius: 15; -fx-padding: 20; -fx-border-color: #2d2d30; -fx-border-radius: 15;">
                                    <children>
                                        <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="LỊCH SỬ ĐẶT GIÁ" />
                                        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
                                            <content>
                                                <VBox fx:id="historyContainer" spacing="12.0">
                                                    <children>
                                                        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: rgba(255,185,95,0.05); -fx-padding: 10; -fx-background-radius: 10; -fx-border-color: #ffb95f; -fx-border-width: 0 0 0 3;">
                                                            <children>
                                                                <Circle fill="#8e8e93" radius="15.0" />
                                                                <VBox HBox.hgrow="ALWAYS">
                                                                    <children>
                                                                        <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12;" text="anhtuan_123 (Bạn)" />
                                                                        <Label style="-fx-text-fill: #8e8e93; -fx-font-size: 10;" text="Vừa xong" />
                                                                    </children>
                                                                </VBox>
                                                                <Label style="-fx-text-fill: #ffb95f; -fx-font-weight: bold;" text="/$42,500" />
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </VBox>
                                            </content>
                                        </ScrollPane>
                                    </children>
                                </VBox>

                                <VBox spacing="20.0" style="-fx-background-color: #1b1b1d; -fx-background-radius: 15; -fx-padding: 25; -fx-border-color: #ffb95f; -fx-border-radius: 15; -fx-border-width: 1;">
                                    <children>
                                        <Label style="-fx-text-fill: #ffb95f; -fx-font-weight: bold; -fx-font-size: 16;" text="BÀN ĐẶT GIÁ" />
                                        <GridPane hgap="10.0" vgap="10.0">
                                            <children>
                                                <Button maxWidth="1.7976931348623157E308" onAction="#addBid100" style="-fx-background-color: #2d2d30; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="+$100" GridPane.columnIndex="0" />
                                                <Button maxWidth="1.7976931348623157E308" onAction="#addBid500" style="-fx-background-color: #2d2d30; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="+$500" GridPane.columnIndex="1" />
                                                <Button maxWidth="1.7976931348623157E308" onAction="#addBid1000" style="-fx-background-color: #2d2d30; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="+$1000" GridPane.columnIndex="2" />
                                            </children>
                                            <columnConstraints>
                                                <ColumnConstraints hgrow="ALWAYS" />
                                                <ColumnConstraints hgrow="ALWAYS" />
                                                <ColumnConstraints hgrow="ALWAYS" />
                                            </columnConstraints>
                                        </GridPane>
                                        <TextField fx:id="bidInputField" prefHeight="50.0" promptText="Nhập số tiền..."
                                                   style="-fx-background-color: #0e0e10; -fx-text-fill: #ffb95f; -fx-border-color: #2d2d30; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 0 15; -fx-font-size: 16;" />
                                        <Button maxWidth="1.7976931348623157E308" onAction="#handleConfirmBid" prefHeight="55.0"
                                                style="-fx-background-color: #ffb95f; -fx-text-fill: #0e0e10; -fx-font-weight: bold; -fx-font-size: 18; -fx-background-radius: 12; -fx-cursor: hand;" text="XÁC NHẬN THẦU" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                    </children>
                </HBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>