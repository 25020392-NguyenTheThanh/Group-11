<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.Group?>

<HBox prefHeight="650.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.group11.controller.LoginController">
    <children>
        <VBox alignment="CENTER" prefWidth="500.0" spacing="30.0" style="-fx-background-color: #0f172a; -fx-padding: 40px;" HBox.hgrow="ALWAYS">
            <children>
                <StackPane prefHeight="350.0">
                    <children>
                        <Group>
                            <children>
                                <Rectangle arcHeight="10.0" arcWidth="10.0" fill="#334155" height="220.0" layoutX="144.0" layoutY="50.0" width="12.0" />
                                <Circle fill="#cbd5e1" layoutX="150.0" layoutY="50.0" radius="15.0" />
                                <Line fx:id="scaleBar" endX="220.0" layoutX="150.0" layoutY="50.0" startX="-140.0" stroke="#cbd5e1" strokeWidth="5.0" />
                            </children>
                        </Group>

                        <VBox fx:id="boxContainer" alignment="CENTER" maxHeight="105.0" maxWidth="100.0" spacing="6.0" style="-fx-background-color: #1e293b; -fx-background-radius: 12; -fx-border-color: #3b82f6; -fx-border-width: 1.2; -fx-border-radius: 12;" translateX="-180.0">
                            <children>
                                <Text fill="#3b82f6" style="-fx-font-size: 32px;" text="📦" />
                                <Label style="-fx-text-fill: white; -fx-font-size: 9px; -fx-font-weight: bold; -fx-background-color: #334155; -fx-padding: 2 6; -fx-background-radius: 8;" text="Inventory Assets" />
                            </children>
                        </VBox>

                        <VBox fx:id="coinContainer" alignment="CENTER" maxHeight="105.0" maxWidth="100.0" spacing="6.0" style="-fx-background-color: #1e293b; -fx-background-radius: 100; -fx-border-color: #10b981; -fx-border-width: 1.2; -fx-border-radius: 100;" translateX="200.0">
                            <children>
                                <Text fill="#10b981" style="-fx-font-size: 32px;" text="💰" />
                                <Label style="-fx-text-fill: white; -fx-font-size: 9px; -fx-font-weight: bold; -fx-background-color: #334155; -fx-padding: 2 6; -fx-background-radius: 8;" text="Global Revenue" />
                            </children>
                        </VBox>
                    </children>
                </StackPane>
                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Text style="-fx-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;" text="Equilibrium for Enterprise" />
                        <Label maxWidth="350" style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;" text="Precision-balanced commerce infrastructure designed for limitless scalability." textAlignment="CENTER" wrapText="true" />
                    </children>
                </VBox>
            </children>
        </VBox>

        <VBox alignment="CENTER_LEFT" prefWidth="500.0" spacing="25.0" style="-fx-background-color: #f7f9fb; -fx-padding: 60px;" HBox.hgrow="ALWAYS">
            <children>
                <VBox spacing="8.0">
                    <children>
                        <Text style="-fx-font-size: 32px; -fx-font-weight: 800; -fx-fill: #191c1e; -fx-font-family: 'Inter', sans-serif;" text="Welcome Back" />
                        <Text style="-fx-fill: #45464d; -fx-font-size: 16px;" text="Login to manage your commerce scale." />
                    </children>
                </VBox>

                <VBox spacing="18.0">
                    <children>
                        <VBox spacing="6.0">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #191c1e; -fx-font-size: 14px;" text="Email" />
                                <TextField fx:id="enterEmail" promptText="Enter email" style="-fx-background-color: white; -fx-border-color: #c6c6cd; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 12px; -fx-font-size: 14px;" />
                            </children>
                        </VBox>
                        <VBox spacing="6.0">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #191c1e; -fx-font-size: 14px;" text="Password" />
                                <PasswordField fx:id="enterPassword" promptText="••••••••" style="-fx-background-color: white; -fx-border-color: #c6c6cd; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 12px; -fx-font-size: 14px;" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <HBox alignment="CENTER_LEFT">
                    <children>
                        <CheckBox fx:id="rememberPassword" style="-fx-text-fill: #45464d; -fx-cursor: hand;" text="Remember password" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Hyperlink fx:id="forgotPassword" style="-fx-text-fill: #0058be; -fx-font-weight: bold; -fx-underline: false;" text="Forgot password?" />
                    </children>
                </HBox>

                <VBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Button fx:id="login" maxWidth="Infinity" style="-fx-background-color: #4169E1; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 14px; -fx-background-radius: 4px; -fx-font-size: 18px; -fx-cursor: hand;" text="Login" />
                        <Button fx:id="createAccount" maxWidth="Infinity" style="-fx-background-color: black; -fx-border-radius: 4px; -fx-background-radius: 4px; -fx-padding: 14px; -fx-text-fill: #ffffff; -fx-font-size: 18px; -fx-cursor: hand;" text="Create new account" />

                        <HBox alignment="CENTER" spacing="5.0" style="-fx-padding: 10px 0 0 0;">
                            <children>
                                <Hyperlink style="-fx-text-fill: #007bff; -fx-underline: false; -fx-font-size: 14px; -fx-padding: 0;" text="Terms of service" />
                                <Text style="-fx-fill: #999999; -fx-font-size: 14px;" text="and" />
                                <Hyperlink style="-fx-text-fill: #007bff; -fx-underline: false; -fx-font-size: 14px; -fx-padding: 0;" text="Privacy policy" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</HBox>