<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="750.0" prefWidth="1100.0"
      style="-fx-background-color: #f7f9fb; -fx-font-family: 'Segoe UI', sans-serif;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.group11.controller.createAccountController">

    <HBox alignment="CENTER" spacing="25.0" VBox.vgrow="ALWAYS">
        <padding><Insets top="50" bottom="50"/></padding>

        <VBox fx:id="Seller" onMouseClicked="#handleSelection" prefWidth="280.0" spacing="20.0"
              style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #e2e8f0; -fx-border-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 5);">
            <padding><Insets bottom="30" left="30" right="30" top="30" /></padding>
            <Label style="-fx-font-size: 28px;" text="👤" />
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Individual" />
            <Label style="-fx-text-fill: #64748b;" text="Perfect for boutique sellers." wrapText="true" />
            <Region VBox.vgrow="ALWAYS" />
            <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-border-color: #131b2e; -fx-border-radius: 8; -fx-text-fill: #131b2e;" text="Choose Basic" />
        </VBox>

        <VBox fx:id="Admin" onMouseClicked="#handleSelection" prefWidth="280.0" spacing="20.0"
              style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #e2e8f0; -fx-border-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 5);">
            <padding><Insets bottom="30" left="30" right="30" top="30" /></padding>
            <Label style="-fx-font-size: 28px;" text="🏢" />
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Enterprise" />
            <Label style="-fx-text-fill: #64748b;" text="Advanced analytics and scaling." wrapText="true" />
            <Region VBox.vgrow="ALWAYS" />
            <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-border-color: #131b2e; -fx-border-radius: 8; -fx-text-fill: #131b2e;" text="Get Started" />
        </VBox>

        <VBox fx:id="Bidder" onMouseClicked="#handleSelection" prefWidth="280.0" spacing="20.0"
              style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #e2e8f0; -fx-border-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 5);">
            <padding><Insets bottom="30" left="30" right="30" top="30" /></padding>
            <Label style="-fx-font-size: 28px;" text="🤝" />
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Partner" />
            <Label style="-fx-text-fill: #64748b;" text="For professional liquidators." wrapText="true" />
            <Region VBox.vgrow="ALWAYS" />
            <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-border-color: #131b2e; -fx-border-radius: 8; -fx-text-fill: #131b2e;" text="Partner With Us" />
        </VBox>
    </HBox>
</VBox>